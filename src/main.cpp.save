cd ~/web-agent
cat > src/main.cpp << 'EOF'
#include <iostream>
#include <string>
#include <cpr/cpr.h>

int main() {
    std::cout << "=== Web Agent v0.1 ===" << std::endl;
    
    // Регистрация на сервере
    std::string url = "https://xdev.arkcom.ru:9999/app/webagent1/api/wa_reg/";
    std::string json_body = "{\"UID\":\"WEBAGENT001\",\"descr\":\"web-agent\"}";
    
    std::cout << "Отправка запроса на: " << url << std::endl;
    
    auto response = cpr::Post(
        cpr::Url{url},
        cpr::Header{{"Content-Type", "application/json"}},
        cpr::Body{json_body}
   я    
    std::cout << "HTTP код: " << response.status_code << std::endl;
    std::cout << "Ответ: " << response.text << std::endl;
    
    return 0;
}
EOF
